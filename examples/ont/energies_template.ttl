                            rdfs:comment "A property that defines the security key of the publication."@en ;
                            rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                            rdfs:label "has key"@en .


###  http://purl.org/gc/hasLastName
<http://purl.org/gc/hasLastName> rdf:type owl:DatatypeProperty ;

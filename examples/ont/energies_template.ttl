<http://purl.org/gc/hasMethodFeature> rdf:type owl:DatatypeProperty ;
                                      rdfs:comment "The upper property for various properties related to computational methods" ;
                                      rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                                      rdfs:label "Generic Datatype Property for Molecular Features related to methods of computations"@en .



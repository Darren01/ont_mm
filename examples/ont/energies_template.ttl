#################################################################
#    Annotations
#################################################################

<http://purl.org/gc/hasAtomProperty> rdfs:comment """A property that allows declaration of a general property 
    	    for an atom, such as NMR shielding."""@en ,
                                                  "A property that allows to declare a general property for an atom."@en ,
                                                  "A property that allows to describe an atom, like NMR Shielding"@en ;
                                     rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                                     rdfs:label "has atom property"@en .


<http://purl.org/gc/hasBasisSet> rdfs:comment "A property that allows Basis Sets to be assigned to a given quantum methodology"@en ,
                                              "A property that allows to define Basis Set -  finite set of functions used to approximately express the Molecular Orbital wavefunction(s) of system, normally atom centered, consisting of AOs differing in local angular momentum for each atom."@en ;
                                 rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                                 rdfs:label "has basis set"@en .


<http://purl.org/gc/hasBondOrder> rdfs:comment "A property that specifies bond order."@en ;
                                  rdfs:label "Bond order"@en .


<http://purl.org/gc/hasBondType> rdfs:comment "A property that describes Bond Type"@en ,
                                              "A property that describes bond type@en " ;
                                 rdfs:label "Bond Type"@en .


<http://purl.org/gc/hasExcitedStateMethod> rdfs:comment "A property that defines the method for the calculation of the excited states of molecules."@en ;
                                           rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                                           rdfs:label "has excited state method"@en .


<http://purl.org/gc/hasFile> rdfs:comment "A property that describes the attachment file."@en ,
                                          "A property that describes the reference to the attachment file."@en ;
                             rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                             rdfs:label "has file"@en .


<http://purl.org/gc/hasForceField> rdfs:comment "A property that describes Force Field."@en ,
                                                "A property that describes a specific force field for given Molecular Mechanics method."@en ;
                                   rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                                   rdfs:label "has force field"@en .


<http://purl.org/gc/hasInputFile> rdfs:comment "A property that specifies input file for calculations."@en ;
                                  rdfs:label "has input file"@en .


<http://purl.org/gc/hasMass> rdfs:comment "A property ..."@en ;
                             rdfs:label "Mass of a molecular entity"@en .


<http://purl.org/gc/hasMethodology> rdfs:comment "A property that describes a methodology of computations."@en ,
                                                 "A property that describes the methodology of the computations."@en ;
                                    rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                                    rdfs:label "has methodology"@en .


<http://purl.org/gc/hasMolecularFeature> rdfs:comment "The upper property for various properties related to Molecular Data" ;
                                         rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                                         rdfs:label "Generic Datatype Property for Molecular Features related to computations"@en .


<http://purl.org/gc/hasMolecularMechanics> rdfs:comment "A property that says (true/false) if there is MM calculation"@en ;
                                           rdfs:label "There is Molecular Mechanical Calculation"@en .


<http://purl.org/gc/hasMultipleDeterminant> rdfs:comment "A property that specifies Multiple Determinant."@en ;
                                            rdfs:label "has multiple determinant"@en .



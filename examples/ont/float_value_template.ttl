                                       rdfs:subClassOf <http://purl.org/gc/GainesvilleCoreTerm> ,
                                                       <http://purl.org/gc/Spectra> ;
                                       rdfs:comment "A class for ElectronicSpectra."@en ,
                                                    "A class for spectra resulting from the molecular electronic transitions."@en ;
                                       rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                                       rdfs:label "Electronic Spectra"@en .


###  http://purl.org/gc/ExchangeFunctional

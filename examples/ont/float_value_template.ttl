                                        rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                                        rdfs:label "Exchange Functional"@en .


###  http://purl.org/gc/FloatValue
<http://purl.org/gc/FloatValue> rdf:type owl:Class ;
                                rdfs:comment "A class for float value, containing value and unit."@en ;
                                rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                                rdfs:label "Float Value"@en .


###  http://purl.org/gc/FrequencyPeak
<http://purl.org/gc/FrequencyPeak> rdf:type owl:Class ;
                                   rdfs:subClassOf <http://purl.org/gc/GainesvilleCoreTerm> ;
                                   rdfs:comment "A class for FrequencyPeak."@en ,
                                                "A class representing frequency peak of the spectrum."@en ;
                                   rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                                   rdfs:label "Frequency Peak"@en .


###  http://purl.org/gc/GainesvilleCoreTerm
<http://purl.org/gc/GainesvilleCoreTerm> rdf:type owl:Class .


###  http://purl.org/gc/GeometryOptimization
<http://purl.org/gc/GeometryOptimization> rdf:type owl:Class ;
                                          rdfs:subClassOf <http://purl.org/gc/MolecularComputation> ;
                                          rdfs:comment "A class for calculations in computational chemistry that aim to find molecular geometry of lowest energy."@en ;
                                          rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                                          rdfs:label "Geometry optimization"@en .


###  http://purl.org/gc/MolecularComputation
<http://purl.org/gc/MolecularComputation> rdf:type owl:Class ;
                                          rdfs:subClassOf <http://purl.org/gc/GainesvilleCoreTerm> ;
                                          rdfs:comment "A class for MolecularComputation."@en ,
                                                       "A class for the specific type of calculation (like optimization, single point, etc) conducted by a computational chemistry program."@en ;
                                          rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                                          rdfs:label "Molecular Computation"@en .


###  http://purl.org/gc/MolecularMethodology
<http://purl.org/gc/MolecularMethodology> rdf:type owl:Class ;
                                          rdfs:subClassOf <http://purl.org/gc/GainesvilleCoreTerm> ;
                                          rdfs:comment "A class for MolecularMethodology."@en ,
                                                       "A class for general methodologies of computational chemistry."@en ;
                                          rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                                          rdfs:label "Molecular Methodology"@en .


###  http://purl.org/gc/Molecule
<http://purl.org/gc/Molecule> rdf:type owl:Class ;
                              rdfs:subClassOf <http://purl.org/gc/GainesvilleCoreTerm> ;
                              <http://purl.obolibrary.org/obo/IAO_0000115> """An electrically neutral entity consisting of more than one atom (n > 1). Rigorously, a molecule, in which (n > 1) must correspond to a
        depression on the potential energy surface that is deep enough to confine at least one vibrational state."""@en ;
                              <http://purl.org/dc/terms/source> "PAC, 1994, 66, 1077. (Glossary of terms used in physical organic chemistry (IUPAC Recommendations 1994)) on page 1143"@en ;
                              rdfs:comment "A class for Molecule."@en ,
                                           "A class for molecule - electrically neutral group (or polyatomic ion) of two or more atoms held together by chemical bonds."@en ;
                              rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                              rdfs:label "Molecule"@en ;
                              rdfs:seeAlso <https://doi.org/10.1351/goldbook.M04002> ,
                                           <https://goldbook.iupac.org/terms/view/M04002> .


###  http://purl.org/gc/NMRSpectra
<http://purl.org/gc/NMRSpectra> rdf:type owl:Class ;
                                rdfs:subClassOf <http://purl.org/gc/Spectra> ;
                                rdfs:comment "A class for nuclear magentic resonance spectra."@en ;
                                rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                                rdfs:label "NMR Spectra"@en .


###  http://purl.org/gc/QuantumMechanics
<http://purl.org/gc/QuantumMechanics> rdf:type owl:Class ;

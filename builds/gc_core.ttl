###  http://purl.org/gc/atomicUnit
:atomicUnit rdf:type owl:NamedIndividual ,
                     <http://qudt.org/schema/qudt/LengthUnit> ;
            rdfs:comment """Atomic Unit this is measure in units of elementary atomic charge called atomicUnits (a.u) .
    The elementary unit of charge (e) is called an atomic unit (a.u.) of charge and is so many Coulombs (1.6 *10**(-19) Coulombs. (float)"""@en ;
            rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
            rdfs:label "Atomic Unit"@en .



#################################################################
#    Annotations
#################################################################

:hasAtomProperty rdfs:comment """A property that allows declaration of a general property 
    	    for an atom, such as NMR shielding."""@en ,
                              "A property that allows to declare a general property for an atom."@en ,
                              "A property that allows to describe an atom, like NMR Shielding"@en ;
                 rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                 rdfs:label "has atom property"@en .


:hasBasisSet rdfs:comment "A property that allows Basis Sets to be assigned to a given quantum methodology"@en ,
                          "A property that allows to define Basis Set -  finite set of functions used to approximately express the Molecular Orbital wavefunction(s) of system, normally atom centered, consisting of AOs differing in local angular momentum for each atom."@en ;
             rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
             rdfs:label "has basis set"@en .


:hasBondOrder rdfs:comment "A property that specifies bond order."@en ;
              rdfs:label "Bond order"@en .


:hasBondType rdfs:comment "A property that describes Bond Type"@en ,
                          "A property that describes bond type@en " ;
             rdfs:label "Bond Type"@en .


:hasExcitedStateMethod rdfs:comment "A property that defines the method for the calculation of the excited states of molecules."@en ;
                       rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                       rdfs:label "has excited state method"@en .


:hasFile rdfs:comment "A property that describes the attachment file."@en ,
                      "A property that describes the reference to the attachment file."@en ;
         rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
         rdfs:label "has file"@en .


:hasForceField rdfs:comment "A property that describes Force Field."@en ,
                            "A property that describes a specific force field for given Molecular Mechanics method."@en ;
               rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
               rdfs:label "has force field"@en .


:hasInputFile rdfs:comment "A property that specifies input file for calculations."@en ;
              rdfs:label "has input file"@en .


:hasMass rdfs:comment "A property ..."@en ;
         rdfs:label "Mass of a molecular entity"@en .


:hasMethodology rdfs:comment "A property that describes a methodology of computations."@en ,
                             "A property that describes the methodology of the computations."@en ;
                rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                rdfs:label "has methodology"@en .


:hasMolecularFeature rdfs:comment "The upper property for various properties related to Molecular Data" ;
                     rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                     rdfs:label "Generic Datatype Property for Molecular Features related to computations"@en .


:hasMolecularMechanics rdfs:comment "A property that says (true/false) if there is MM calculation"@en ;
                       rdfs:label "There is Molecular Mechanical Calculation"@en .


:hasMultipleDeterminant rdfs:comment "A property that specifies Multiple Determinant."@en ;
                        rdfs:label "has multiple determinant"@en .


:hasNumber rdfs:comment "A property of having a number"@en ;
           rdfs:label "Number"@en .


:hasNumberOfAtoms rdfs:comment "A property that determines the number of atoms in a given collection"@en ;
                  rdfs:label "Number of Atoms"@en .


:hasOccupiedOrbitalsIncluded rdfs:comment "A property that describes the inclusion of occupied orbitals in electronic spectra calculations."@en ;
                             rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                             rdfs:label "has occupied orbitals included"@en .


:hasOpenShellTreatment rdfs:comment "A property that describes the treatment of open shell systems."@en ;
                       rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                       rdfs:label "has open shell treatment"@en .


:hasOrbitalCount rdfs:comment "A property that defines the number of electron orbitals"@en ;
                 rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                 rdfs:label "has orbital count"@en .


:hasOrbitalSymmetry rdfs:comment "A property that defines Orbital symmetry"@en ;
                    rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                    rdfs:label "has orbital symmetry"@en .


:hasParameterSet rdfs:comment "A property that defines the parametr set for calculations."@en ,
                              "A property that describes a specific parameter set for Molecular Mechanics calculations."@en ;
                 rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                 rdfs:label "has parameter set"@en .


:hasPeakCount rdfs:comment "A property that determinates the count of peaks in a spectrum."@en ;
              rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
              rdfs:label "has peak count"@en .


:hasPropertyCount rdfs:comment "A property that reports property count"@en ;
                  rdfs:label "Property Count"@en .


:hasQuantumMechanics rdfs:comment "A property that says (true/false) if there is QM calculation"@en ;
                     rdfs:label "There is Quantum Mechanical Calculation"@en .


:hasSource rdfs:comment "A property that describes the software package used for calculations."@en ;
           rdfs:label "has source"@en .


:hasSpinType rdfs:comment "A property that defines the spin type."@en ,
                          "A property that describes handling of spins by the methodology (RHF,UHF,ROHF)."@en ;
             rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
             rdfs:label "has spin type"@en .


:hasSystemMultiplicity rdfs:comment """The spin multiplicity of the molecular system, 
    	    defined as 2S+1 where S is the total spin. Singlet=1, doublet=2, triplet=3 etc.  
    	    Always a positive integer."""@en ;
                       rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                       rdfs:label "has system multiplicity"@en .


:hasTag rdfs:comment "A property that reports tags assigned to publication"@en ;
        rdfs:label "Tag for the calculation"@en .


:hasTextValue rdfs:comment "A property ..."@en ;
              rdfs:label "Text Value"@en .


:hasTransitionCount rdfs:comment "A property that describes the number of the electronic transitions in spectral calculations."@en ;
                    rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                    rdfs:label "has transition count"@en .


:hasUnoccupiedOrbitalsIncluded rdfs:comment "A property that describes the inclusion of occupied orbitals in electronic spectra calculations."@en ;
                               rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                               rdfs:label "has unoccupied orbitals included"@en .


:hasVibrationCount rdfs:comment "A property that describes the number of vibrational frequencies."@en ;
                   rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                   rdfs:label "has vibration count"@en .



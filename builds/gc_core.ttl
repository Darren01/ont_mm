###  http://purl.org/gc/Atom
:Atom rdf:type owl:Class ;
      rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000030> ,
                      :GainesvilleCoreTerm ,
                      :MolecularStructureObject ;
      owl:disjointWith :Bond ;
      <http://purl.obolibrary.org/obo/IAO_0000115> """Smallest particle still characterizing a chemical element. It consists of a nucleus of a positive charge (Z is the proton number and e the
        elementary charge) carrying almost all its mass (more than 99.9%) and electrons determining its size."""@en ;
      <http://purl.org/dc/terms/source> "Red Book, 3rd ed., p. 35"@en ;
      rdfs:comment "A class for Atom."@en ,
                   "A class for atoms, the basic unit of matter."@en ;
      rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
      rdfs:label "Atom"@en ;
      rdfs:seeAlso <https://doi.org/10.1351/goldbook.A00493> ,
                   <https://goldbook.iupac.org/terms/view/A00493> .



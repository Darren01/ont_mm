###  http://purl.org/gc/BasisSet
:BasisSet rdf:type owl:Class ;
          rdfs:subClassOf :MethodologyFeature ;
          <http://purl.obolibrary.org/obo/IAO_0000115> """A set of basis functions employed for the representation of molecular orbitals. One may distinguish the minimal basis set (includes one basis
        function for each SCF occupied atomic orbital with distinct principal and angular momentum quantum numbers); split valence basis set (includes two or more sizes of basis 
        function for each valence orbital); double zeta (DZ) basis set (a split valence basis set that includes exactly twice as many functions as the minimal basis set); extended
        basis set (the set larger than the double zeta basis set); polarized basis set (incorporates basis functions of higher angular quantum number beyond what is required by the
        atom in its electronic ground state; allows orbitals to change not only a size, but also a shape); basis set with diffuse functions and others."""@en ;
          <http://purl.org/dc/terms/source> "PAC, 1999, 71, 1919. Glossary of terms used in theoretical organic chemistry, page 1925"@en ;
          rdfs:comment """A class for the basis set. In computational chemistry basis set is a set of functions which are combined to create molecular orbitals.
        """@en ;
          rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
          rdfs:label "Basis Set"@en ;
          rdfs:seeAlso <https://doi.org/10.1351/goldbook.BT06999> ,
                       <https://goldbook.iupac.org/terms/view/BT06999> .


###  http://purl.org/gc/Becke88
:Becke88 rdf:type owl:Class ;
         rdfs:subClassOf :ExchangeFunctional ;
         rdfs:comment "Becke 1988 exchange functional"@en ;
         rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
         rdfs:label "Becke88"@en .


###  http://purl.org/gc/BetaOrbital
:BetaOrbital rdf:type owl:Class ;
             rdfs:subClassOf :GainesvilleCoreTerm ;
             rdfs:comment "A class for BetaOrbital."@en ;
             rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
             rdfs:label "BetaOrbital"@en .


###  http://purl.org/gc/Bond
:Bond rdf:type owl:Class ;
      rdfs:subClassOf :MolecularStructureObject ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :binds ;
                        owl:cardinality "2"^^xsd:nonNegativeInteger
                      ] ;
      <http://purl.obolibrary.org/obo/IAO_0000115> """There is a chemical bond between two atoms or groups of atoms in the case that the forces acting between them are such as to lead to the
    formation of an aggregate with sufficient stability to make it convenient for the chemist to consider it as an independent 'molecular species'."""@en ;
      <http://purl.org/dc/terms/source> "PAC, 1994, 66, 1077. (Glossary of terms used in physical organic chemistry (IUPAC Recommendations 1994)) on page 1089."@en ;
      rdfs:comment "A class for generic chemical bond."@en ,
                   "A generic chemical bond between two atoms."@en ;
      rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
      rdfs:label "Bond"@en ;
      rdfs:seeAlso <https://doi.org/10.1351/goldbook.B00697> ,
                   <https://goldbook.iupac.org/terms/view/B00697> .



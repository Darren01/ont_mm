       rdfs:comment "A property that describes what is on xAxis"@en ;
       rdfs:label "x Axis"@en .


###  http://purl.org/gc/xAxisUnit
:xAxisUnit rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :extraGCObjectProperty ;
           rdfs:comment "A property that describes Units of X Axis"@en ;
           rdfs:label "X Axis Unit"@en .


###  http://purl.org/gc/yAxis
:yAxis rdf:type owl:ObjectProperty ;
       rdfs:subPropertyOf :extraGCObjectProperty ;
       rdfs:domain :InfraRedSpectrum ;
       rdfs:comment "A property that describes what is on Axis"@en ;
       rdfs:label "Y Axis"@en .


###  http://purl.org/gc/yAxisUnit
:yAxisUnit rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :extraGCObjectProperty ;
           rdfs:domain :InfraRedSpectrum ;
           rdfs:comment "A property that describes Units of X Axis"@en ;
           rdfs:label "Y Axis Unit"@en .


###  http://www.w3.org/ns/prov#activity
<http://www.w3.org/ns/prov#activity> rdf:type owl:ObjectProperty ;
                                     rdfs:domain <http://www.w3.org/ns/prov#ActivityInfluence> ;
                                     rdfs:range <http://www.w3.org/ns/prov#Activity> ;
                                     rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ;
                                     rdfs:label "activity" ;
                                     <http://www.w3.org/ns/prov#category> "qualified" ;
                                     <http://www.w3.org/ns/prov#editorialNote> "This property behaves in spirit like rdf:object; it references the object of a prov:wasInfluencedBy triple."@en ;
                                     <http://www.w3.org/ns/prov#editorsDefinition> "The prov:activity property references an prov:Activity which influenced a resource. This property applies to an prov:ActivityInfluence, which is given by a subproperty of prov:qualifiedInfluence from the influenced prov:Entity, prov:Activity or prov:Agent." ;
                                     <http://www.w3.org/ns/prov#inverse> "activityOfInfluence" .


###  http://www.w3.org/ns/prov#alternateOf
<http://www.w3.org/ns/prov#alternateOf> rdf:type owl:ObjectProperty ;
                                        rdfs:domain <http://www.w3.org/ns/prov#Entity> ;
                                        rdfs:range <http://www.w3.org/ns/prov#Entity> ;
                                        rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ;
                                        rdfs:label "alternateOf" ;
                                        rdfs:seeAlso <http://www.w3.org/ns/prov#specializationOf> ;
                                        <http://www.w3.org/ns/prov#category> "expanded" ;
                                        <http://www.w3.org/ns/prov#component> "alternate" ;
                                        <http://www.w3.org/ns/prov#constraints> "http://www.w3.org/TR/2013/REC-prov-constraints-20130430/#prov-dm-constraints-fig"^^xsd:anyURI ;
                                        <http://www.w3.org/ns/prov#definition> "Two alternate entities present aspects of the same thing. These aspects may be the same or different, and the alternate entities may or may not overlap in time."@en ;
                                        <http://www.w3.org/ns/prov#dm> "http://www.w3.org/TR/2013/REC-prov-dm-20130430/#term-alternate"^^xsd:anyURI ;
                                        <http://www.w3.org/ns/prov#inverse> "alternateOf" ;
                                        <http://www.w3.org/ns/prov#n> "http://www.w3.org/TR/2013/REC-prov-n-20130430/#expression-alternate"^^xsd:anyURI .


###  http://www.w3.org/ns/prov#entity
<http://www.w3.org/ns/prov#entity> rdf:type owl:ObjectProperty ;
                                   rdfs:domain <http://www.w3.org/ns/prov#EntityInfluence> ;
                                   rdfs:range <http://www.w3.org/ns/prov#Entity> ;
                                   rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ;
                                   rdfs:label "entity" ;
                                   <http://www.w3.org/ns/prov#category> "qualified" ;
                                   <http://www.w3.org/ns/prov#editorialNote> "This property behaves in spirit like rdf:object; it references the object of a prov:wasInfluencedBy triple."@en ;
                                   <http://www.w3.org/ns/prov#editorsDefinition> "The prov:entity property references an prov:Entity which influenced a resource. This property applies to an prov:EntityInfluence, which is given by a subproperty of prov:qualifiedInfluence from the influenced prov:Entity, prov:Activity or prov:Agent." ;
                                   <http://www.w3.org/ns/prov#inverse> "entityOfInfluence" .


###  http://www.w3.org/ns/prov#generated
<http://www.w3.org/ns/prov#generated> rdf:type owl:ObjectProperty ;
                                      owl:inverseOf <http://www.w3.org/ns/prov#wasGeneratedBy> ;
                                      rdfs:domain <http://www.w3.org/ns/prov#Activity> ;
                                      rdfs:range <http://www.w3.org/ns/prov#Entity> ;
                                      rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ;
                                      rdfs:label "generated" ;
                                      <http://www.w3.org/ns/prov#category> "expanded" ;
                                      <http://www.w3.org/ns/prov#component> "entities-activities" ;
                                      <http://www.w3.org/ns/prov#editorialNote> "prov:generated is one of few inverse property defined, to allow Activity-oriented assertions in addition to Entity-oriented assertions."@en ;
                                      <http://www.w3.org/ns/prov#inverse> "wasGeneratedBy" ;
                                      <http://www.w3.org/ns/prov#sharesDefinitionWith> <http://www.w3.org/ns/prov#Generation> .


###  http://www.w3.org/ns/prov#specializationOf
<http://www.w3.org/ns/prov#specializationOf> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf <http://www.w3.org/ns/prov#alternateOf> ;
                                             rdfs:domain <http://www.w3.org/ns/prov#Entity> ;
                                             rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ;
                                             rdfs:label "specializationOf" ;
                                             rdfs:seeAlso <http://www.w3.org/ns/prov#alternateOf> ;
                                             <http://www.w3.org/ns/prov#category> "expanded" ;
                                             <http://www.w3.org/ns/prov#component> "alternate" ;
                                             <http://www.w3.org/ns/prov#constraints> "http://www.w3.org/TR/2013/REC-prov-constraints-20130430/#prov-dm-constraints-fig"^^xsd:anyURI ;
                                             <http://www.w3.org/ns/prov#definition> "An entity that is a specialization of another shares all aspects of the latter, and additionally presents more specific aspects of the same thing as the latter. In particular, the lifetime of the entity being specialized contains that of any specialization. Examples of aspects include a time period, an abstraction, and a context associated with the entity."@en ;
                                             <http://www.w3.org/ns/prov#dm> "http://www.w3.org/TR/2013/REC-prov-dm-20130430/#term-specialization"^^xsd:anyURI ;
                                             <http://www.w3.org/ns/prov#inverse> "generalizationOf" ;
                                             <http://www.w3.org/ns/prov#n> "http://www.w3.org/TR/2013/REC-prov-n-20130430/#expression-specialization"^^xsd:anyURI .


###  http://www.w3.org/ns/prov#used
<http://www.w3.org/ns/prov#used> rdf:type owl:ObjectProperty ;
                                 rdfs:domain <http://www.w3.org/ns/prov#Activity> ;
                                 rdfs:range <http://www.w3.org/ns/prov#Entity> ;
                                 rdfs:comment "A prov:Entity that was used by this prov:Activity. For example, :baking prov:used :spoon, :egg, :oven ."@en ;
                                 rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ;
                                 rdfs:label "used" ;
                                 <http://www.w3.org/ns/prov#category> "starting-point" ;
                                 <http://www.w3.org/ns/prov#component> "entities-activities" ;
                                 <http://www.w3.org/ns/prov#inverse> "wasUsedBy" ;
                                 <http://www.w3.org/ns/prov#qualifiedForm> <http://www.w3.org/ns/prov#Usage> ,
                                                                           <http://www.w3.org/ns/prov#qualifiedUsage> .


###  http://www.w3.org/ns/prov#wasDerivedFrom
<http://www.w3.org/ns/prov#wasDerivedFrom> rdf:type owl:ObjectProperty ;
                                           rdfs:domain <http://www.w3.org/ns/prov#Entity> ;
                                           rdfs:range <http://www.w3.org/ns/prov#Entity> ;
                                           rdfs:comment "The more specific subproperties of prov:wasDerivedFrom (i.e., prov:wasQuotedFrom, prov:wasRevisionOf, prov:hadPrimarySource) should be used when applicable."@en ;
                                           rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ;
                                           rdfs:label "wasDerivedFrom" ;
                                           <http://www.w3.org/ns/prov#category> "starting-point" ;
                                           <http://www.w3.org/ns/prov#component> "derivations" ;
                                           <http://www.w3.org/ns/prov#definition> "A derivation is a transformation of an entity into another, an update of an entity resulting in a new one, or the construction of a new entity based on a pre-existing entity."@en ;
                                           <http://www.w3.org/ns/prov#inverse> "hadDerivation" ;
                                           <http://www.w3.org/ns/prov#qualifiedForm> <http://www.w3.org/ns/prov#Derivation> ,
                                                                                     <http://www.w3.org/ns/prov#qualifiedDerivation> .


###  http://www.w3.org/ns/prov#wasGeneratedBy
<http://www.w3.org/ns/prov#wasGeneratedBy> rdf:type owl:ObjectProperty ;
                                           rdfs:domain <http://www.w3.org/ns/prov#Entity> ;
                                           rdfs:range <http://www.w3.org/ns/prov#Activity> ;
                                           rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ;
                                           rdfs:label "wasGeneratedBy" ;
                                           <http://www.w3.org/ns/prov#category> "starting-point" ;
                                           <http://www.w3.org/ns/prov#component> "entities-activities" ;
                                           <http://www.w3.org/ns/prov#inverse> "generated" ;
                                           <http://www.w3.org/ns/prov#qualifiedForm> <http://www.w3.org/ns/prov#Generation> ,
                                                                                     <http://www.w3.org/ns/prov#qualifiedGeneration> .


###  http://www.w3.org/ns/prov#wasRevisionOf
<http://www.w3.org/ns/prov#wasRevisionOf> rdf:type owl:ObjectProperty ;
                                          rdfs:subPropertyOf <http://www.w3.org/ns/prov#wasDerivedFrom> ;
                                          rdfs:domain <http://www.w3.org/ns/prov#Entity> ;
                                          rdfs:comment "A revision is a derivation that revises an entity into a revised version."@en ;
                                          rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ;
                                          rdfs:label "wasRevisionOf" ;
                                          <http://www.w3.org/ns/prov#category> "expanded" ;
                                          <http://www.w3.org/ns/prov#component> "derivations" ;
                                          <http://www.w3.org/ns/prov#inverse> "hadRevision" ;
                                          <http://www.w3.org/ns/prov#qualifiedForm> <http://www.w3.org/ns/prov#Revision> ,
                                                                                    <http://www.w3.org/ns/prov#qualifiedRevision> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource <http://www.w3.org/ns/prov#wasRevisionOf> ;
   owl:annotatedProperty rdfs:subPropertyOf ;
   owl:annotatedTarget <http://www.w3.org/ns/prov#wasDerivedFrom> ;
   rdfs:comment """Revision is a derivation (see http://www.w3.org/TR/prov-dm/#term-Revision). Moreover, according to 
http://www.w3.org/TR/2013/REC-prov-constraints-20130430/#term-Revision 23 April 2012 'wasRevisionOf is a strict sub-relation of wasDerivedFrom since two entities e2 and e1 may satisfy wasDerivedFrom(e2,e1) without being a variant of each other.'"""
 ] .


#################################################################
#    Data properties
#################################################################

###  http://purl.org/gc/extraGCDataProperty
:extraGCDataProperty rdf:type owl:DatatypeProperty .


###  http://purl.org/gc/hasAtomCount
:hasAtomCount rdf:type owl:DatatypeProperty ;
              owl:equivalentProperty :hasNumberOfAtoms ;
              rdfs:subPropertyOf :hasMolecularData ;
              rdf:type owl:FunctionalProperty ;
              rdfs:domain [ rdf:type owl:Class ;
                            owl:unionOf ( :MolecularSystem
                                          :Molecule
                                          :Residue
                                        )
                          ] ;
              rdfs:range xsd:nonNegativeInteger ;
              rdfs:comment "A property that allows to declare total count of atoms in a given structure - Molecular System or Molecule or Residue."@en ;
              rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
              rdfs:label "has number of atoms"@en .


###  http://purl.org/gc/hasAtomProperty
:hasAtomProperty rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf :hasMolecularData .


###  http://purl.org/gc/hasBasisSet
:hasBasisSet rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:range rdfs:Literal .


###  http://purl.org/gc/hasBondCount
:hasBondCount rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf :hasMolecularData ;
              rdf:type owl:FunctionalProperty ;
              rdfs:domain [ rdf:type owl:Class ;
                            owl:unionOf ( :Atom
                                          :Molecule
                                          :Residue
                                        )
                          ] ;
              rdfs:range xsd:nonNegativeInteger ;
              rdfs:comment "A property that determinates the count of bonds into Molecule, Residue or Atom."@en ;
              rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
              rdfs:label "has bond count"@en .


###  http://purl.org/gc/hasBondOrder
:hasBondOrder rdf:type owl:DatatypeProperty ;
              rdfs:range xsd:positiveInteger .


###  http://purl.org/gc/hasBondType
:hasBondType rdf:type owl:DatatypeProperty .


###  http://purl.org/gc/hasCategory
:hasCategory rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf :hasPublicationData ;
             rdfs:domain :ComputationalChemistryPublication ;
             rdfs:range xsd:string ;
             rdfs:comment "A property that determines a category of the publication."@en ;
             rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
             rdfs:label "has category"@en .


###  http://purl.org/gc/hasChainNumber
:hasChainNumber rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf :hasMolecularData ;
                rdfs:domain :Residue ;
                rdfs:range xsd:int ;
                rdfs:comment "A property that defines chain number in the molecule."@en ;
                rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                rdfs:label "has chain number"@en .


###  http://purl.org/gc/hasElementSymbol
:hasElementSymbol rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf :hasMolecularData ;
                  rdf:type owl:FunctionalProperty ;
                  rdfs:domain :Atom ;
                  rdfs:range xsd:string ;
                  rdfs:comment "A property that defines the Symbol of the element of an atom."@en ;
                  rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                  rdfs:label "has element symbol"@en .


###  http://purl.org/gc/hasEmail
:hasEmail rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf :hasPublicationData ;
          rdfs:domain :Author ;
          rdfs:range xsd:string ;
          rdfs:comment "A property that describes the email address of corresponding author."@en ;
          rdfs:label "has email" .


###  http://purl.org/gc/hasExcitedStateMethod
:hasExcitedStateMethod rdf:type owl:DatatypeProperty ,
                                owl:FunctionalProperty ;
                       rdfs:range rdfs:Literal .


###  http://purl.org/gc/hasFile
:hasFile rdf:type owl:DatatypeProperty ;
         rdfs:subPropertyOf :hasPublicationData .


###  http://purl.org/gc/hasFirstName
:hasFirstName rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf :hasPublicationData ;
              rdfs:domain :Author ;
              rdfs:range xsd:string ;
              rdfs:comment "A property that describes the first name of corresponding author."@en ;
              rdfs:label "has first name" .


###  http://purl.org/gc/hasFloatValue
:hasFloatValue rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf :hasValue ;
               rdf:type owl:FunctionalProperty ;
               rdfs:domain :FloatValue ;
               rdfs:range xsd:float ;
               rdfs:comment "A property that describes floating point value."@en ;
               rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
               rdfs:label "has float value"@en .


###  http://purl.org/gc/hasForceField
:hasForceField rdf:type owl:DatatypeProperty ;
               rdfs:range xsd:string .


###  http://purl.org/gc/hasInChIKey
:hasInChIKey rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf :hasMolecularData ;
             rdf:type owl:FunctionalProperty ;
             rdfs:domain :Molecule ;
             rdfs:range xsd:string ;
             rdfs:comment "A property that describes the InChI Key - the condensed, 27 character hashed version of the InChI String."@en ;
             rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
             rdfs:label "has InChI key"@en .


###  http://purl.org/gc/hasInChIString
:hasInChIString rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf :hasMolecularData ;
                rdf:type owl:FunctionalProperty ;
                rdfs:domain :Molecule ;
                rdfs:range xsd:string ;
                rdfs:comment "A property that describes the InChI String - International Chemical Identifier - a textual identifier for chemical substances."@en ;
                rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                rdfs:label "has InChI string"@en .


###  http://purl.org/gc/hasIndex
:hasIndex rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf :hasMolecularData ;
          rdfs:range xsd:nonNegativeInteger ;
          rdfs:comment "A property that defines a sequential arrangement of material in numerical order, i.e. Frequency Peak, Orbital or a sequence number in residue."@en ;
          rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
          rdfs:label "has index"@en .


###  http://purl.org/gc/hasInput
:hasInput rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf :hasPublicationData ;
          rdfs:domain :SourcePackage ;
          rdfs:range xsd:string ;
          rdfs:comment "A property that defines the contents of the input file of the calculation."@en ;
          rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
          rdfs:label "has input"@en .


###  http://purl.org/gc/hasInputFile
:hasInputFile rdf:type owl:DatatypeProperty ;
              rdfs:range xsd:string .


###  http://purl.org/gc/hasInsertion
:hasInsertion rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf :hasMolecularData ;
              rdfs:domain :Residue ;
              rdfs:comment "A property that defines the insertion code for residue numbering."@en ;
              rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
              rdfs:label "has insertion code"@en .


###  http://purl.org/gc/hasIntegerValue
:hasIntegerValue rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf :hasValue ;
                 rdf:type owl:FunctionalProperty ;
                 rdfs:domain :IntegerValue ;
                 rdfs:range xsd:integer ;
                 rdfs:comment "A property that describes Integer Value."@en ;
                 rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                 rdfs:label "has integer value"@en .


###  http://purl.org/gc/hasKey
:hasKey rdf:type owl:DatatypeProperty ;
        rdfs:subPropertyOf :hasPublicationData ;
        rdfs:domain :ComputationalChemistryPublication ;
        rdfs:range xsd:string ;
        rdfs:comment "A property that defines the security key of the publication."@en ;
        rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
        rdfs:label "has key"@en .


###  http://purl.org/gc/hasLastName
:hasLastName rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf :hasPublicationData ;
             rdfs:domain :Author ;
             rdfs:range xsd:string ;
             rdfs:comment "A property that describes the last name of corresponding author."@en ;
             rdfs:label "has last name" .


###  http://purl.org/gc/hasMass
:hasMass rdf:type owl:DatatypeProperty ;
         rdfs:subPropertyOf :hasMolecularData .


###  http://purl.org/gc/hasMethod
:hasMethod rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf :hasMethodFeature ;
           rdf:type owl:FunctionalProperty ;
           rdfs:range rdfs:Literal ;
           rdfs:comment "A property that defines the calculation method for given technology."@en ;
           rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
           rdfs:label "has method"@en .


###  http://purl.org/gc/hasMethodFeature
:hasMethodFeature rdf:type owl:DatatypeProperty ;
                  rdfs:comment "The upper property for various properties related to computational methods" ;
                  rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                  rdfs:label "Generic Datatype Property for Molecular Features related to methods of computations"@en .


###  http://purl.org/gc/hasMethodology
:hasMethodology rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf :hasMethodFeature ;
                rdfs:range xsd:string .


###  http://purl.org/gc/hasMolecularData
:hasMolecularData rdf:type owl:DatatypeProperty ;
                  rdfs:comment "The upper property for various properties related to Molecular Data" ;
                  rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                  rdfs:label "Generic Datatype Property for Molecular Data"@en .


###  http://purl.org/gc/hasMolecularFeature
:hasMolecularFeature rdf:type owl:DatatypeProperty .


###  http://purl.org/gc/hasMolecularMechanics
:hasMolecularMechanics rdf:type owl:DatatypeProperty .


###  http://purl.org/gc/hasMultipleDeterminant
:hasMultipleDeterminant rdf:type owl:DatatypeProperty ;
                        rdfs:range xsd:positiveInteger .


###  http://purl.org/gc/hasName
:hasName rdf:type owl:DatatypeProperty ;
         rdfs:subPropertyOf :hasMolecularData ;
         rdfs:range rdfs:Literal ,
                    xsd:string ;
         rdfs:comment "A property that defines the name of molecular system elements, i.e. atom or residue."@en ,
                      "The name of an entity." ;
         rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
         rdfs:label "has name"@en .


###  http://purl.org/gc/hasNaturalValue
:hasNaturalValue rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf :hasValue ;
                 rdf:type owl:FunctionalProperty ;
                 rdfs:domain :NaturalValue ;
                 rdfs:range xsd:nonNegativeInteger ;
                 rdfs:comment "A property that defines natural value."@en ;
                 rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                 rdfs:label "has natural value"@en .


###  http://purl.org/gc/hasNumber
:hasNumber rdf:type owl:DatatypeProperty .


###  http://purl.org/gc/hasNumberOfAtoms
:hasNumberOfAtoms rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf :hasMolecularData .


###  http://purl.org/gc/hasOccupiedOrbitalsIncluded
:hasOccupiedOrbitalsIncluded rdf:type owl:DatatypeProperty ;
                             rdfs:range xsd:int .


###  http://purl.org/gc/hasOpenShellTreatment
:hasOpenShellTreatment rdf:type owl:DatatypeProperty ;
                       rdfs:range rdfs:Literal .


###  http://purl.org/gc/hasOrbitalCount
:hasOrbitalCount rdf:type owl:DatatypeProperty ;
                 rdfs:range xsd:int .


###  http://purl.org/gc/hasOrbitalSymmetry
:hasOrbitalSymmetry rdf:type owl:DatatypeProperty ;
                    rdfs:range xsd:string .


###  http://purl.org/gc/hasOrganization
:hasOrganization rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf :hasPublicationData ;
                 rdfs:domain :Author ;
                 rdfs:range xsd:string ;
                 rdfs:comment "A property that describes the organization of corresponding author."@en ;
                 rdfs:label "has organization" .


###  http://purl.org/gc/hasOutput
:hasOutput rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf :hasPublicationData ;
           rdfs:domain :SourcePackage ;
           rdfs:range xsd:string ;
           rdfs:comment "The property that defines the contents of the output file of the calculation."@en ;
           rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
           rdfs:label "has output"@en .


###  http://purl.org/gc/hasParameterSet
:hasParameterSet rdf:type owl:DatatypeProperty ;
                 rdfs:range xsd:string .


###  http://purl.org/gc/hasPeakCount
:hasPeakCount rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf :hasMolecularData ;
              rdf:type owl:FunctionalProperty ;
              rdfs:range xsd:nonNegativeInteger .


###  http://purl.org/gc/hasPropertyCount
:hasPropertyCount rdf:type owl:DatatypeProperty ;
                  rdfs:range xsd:unsignedInt .


###  http://purl.org/gc/hasPublicationData
:hasPublicationData rdf:type owl:DatatypeProperty ;
                    rdfs:comment "The upper property for various properties related to the publication data" ;
                    rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                    rdfs:label "Generic Datatype Property for Publication data"@en .


###  http://purl.org/gc/hasQuantumMechanics
:hasQuantumMechanics rdf:type owl:DatatypeProperty .


###  http://purl.org/gc/hasSecondaryStructure
:hasSecondaryStructure rdf:type owl:DatatypeProperty ;
                       rdfs:subPropertyOf :hasMolecularData ;
                       rdfs:domain :Residue ;
                       rdfs:range rdfs:Literal ;
                       rdfs:comment "A property that defines the three-dimensional form of local segments of biopolymers."@en ;
                       rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                       rdfs:label "has secondary structure"@en .


###  http://purl.org/gc/hasSource
:hasSource rdf:type owl:DatatypeProperty ;
           rdfs:range rdfs:Literal .


###  http://purl.org/gc/hasSpinType
:hasSpinType rdf:type owl:DatatypeProperty ;
             rdfs:range rdfs:Literal .


###  http://purl.org/gc/hasStatus
:hasStatus rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf :hasPublicationData ;
           rdfs:domain :ComputationalChemistryPublication ;
           rdfs:range xsd:string ;
           rdfs:comment "A property that describes the status of the publication."@en ;
           rdfs:label "has status" .


###  http://purl.org/gc/hasSystemMultiplicity
:hasSystemMultiplicity rdf:type owl:DatatypeProperty ,
                                owl:FunctionalProperty ;
                       rdfs:range xsd:positiveInteger .


###  http://purl.org/gc/hasTag
:hasTag rdf:type owl:DatatypeProperty ;
        rdfs:range rdfs:Literal .


###  http://purl.org/gc/hasTechnology
:hasTechnology rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf :hasMethodFeature ;
               rdf:type owl:FunctionalProperty ;
               rdfs:range rdfs:Literal ;
               rdfs:comment "A property that describes the calculation's technology for molecular system."@en ;
               rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
               rdfs:label "has technology"@en .


###  http://purl.org/gc/hasTextValue
:hasTextValue rdf:type owl:DatatypeProperty .


###  http://purl.org/gc/hasTransitionCount
:hasTransitionCount rdf:type owl:DatatypeProperty ,
                             owl:FunctionalProperty ;
                    rdfs:range xsd:int .


###  http://purl.org/gc/hasUnoccupiedOrbitalsIncluded
:hasUnoccupiedOrbitalsIncluded rdf:type owl:DatatypeProperty ;
                               rdfs:range xsd:int .


###  http://purl.org/gc/hasValue
:hasValue rdf:type owl:DatatypeProperty ,
                   owl:FunctionalProperty ;
          rdfs:domain :Value ;
          rdfs:range rdfs:Literal ;
          rdfs:comment "A Superproperty of typed numerical values."@en ;
          rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
          rdfs:label "has value"@en .


###  http://purl.org/gc/hasVectorValue
:hasVectorValue rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf :hasValue ;
                rdf:type owl:FunctionalProperty ;
                rdfs:domain :VectorValue ;
                rdfs:range rdfs:Literal ;
                rdfs:comment "A property that describes the vector values."@en ;
                rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                rdfs:label "has vector value"@en .


###  http://purl.org/gc/hasVersion
:hasVersion rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf :hasPublicationData ;
            rdfs:domain :SourcePackage ;
            rdfs:range xsd:string ;
            rdfs:comment "A property that describes the version of the software package used."@en ;
            rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
            rdfs:label "has version"@en .


###  http://purl.org/gc/hasVibrationCount
:hasVibrationCount rdf:type owl:DatatypeProperty ,
                            owl:FunctionalProperty .


###  http://purl.org/gc/hasVisibility
:hasVisibility rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf :hasPublicationData ;
               rdfs:domain :ComputationalChemistryPublication ;
               rdfs:range xsd:string ;
               rdfs:comment "A property that defines the allowed visibility of the publication."@en ;
               rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
               rdfs:label "has visibility"@en .



                 rdfs:subClassOf :SystemEnergies ;
                 <http://purl.obolibrary.org/obo/IAO_0000115> "Extent, in consequence of Heisenberg's Uncertainty Principle, by which a particle or a set of particles has an energy greater than that of the minimum on the potential-energy surface."@en ;
                 <http://purl.org/dc/terms/source> "PAC, 2022, 94, 353. (Glossary of terms used in physical organic chemistry (IUPAC Recommendations 2021)) on page 525."@en ;
                 rdfs:comment "A class for zero-point energy."@en ;
                 rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                 rdfs:label "Zero-Point Energy"@en ;
                 rdfs:seeAlso <https://doi.org/10.1351/goldbook.08215> ,
                              <https://goldbook.iupac.org/terms/view/08215> .



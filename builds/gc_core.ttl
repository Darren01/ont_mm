@prefix : <http://purl.org/gc/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://purl.org/gc/> .

<http://purl.org/gc/> rdf:type owl:Ontology ;
                       owl:versionIRI <http://purl.org/gc/0.8.4> ;
                       <http://creativecommons.org/ns#license> <http://creativecommons.org/licenses/by/3.0/> ;
                       <http://purl.org/dc/elements/1.1/created> "2015-03-04" ;
                       <http://purl.org/dc/elements/1.1/description> """This ontology aims at complete description of typical Computational Chemistry experiment.
    Gainesville Core describes:
    - Molecular Publications
    - Molecular Systems
    - Molecular Calculations

    Molecular Systems contains Molecules
    The Molecules may have Residues (for biopolymers and polymers)
    Molecular Calculations contain Initial Data and Results
    The Initial Data may have Methods, Basis Sets, Functionals, etc.
    The Results may have Energies, Wave Functions and Spectra, etc.""" ;
                       <http://purl.org/dc/elements/1.1/modified> "2026-06-28" ;
                       <http://purl.org/dc/terms/contributor> "Darren Rhodes (ont_mm project) - structural repairs v0.8.0, with AI-assisted tooling support (Claude, Anthropic)"@en ;
                       <http://purl.org/dc/terms/creator> "Chemical Semantics, Inc."@en ;
                       <http://purl.org/dc/terms/description> "A core ontology for quantum chemistry calculations combining the Gainesville Core Ontology and PROV-O provenance terms." ;
                       <http://purl.org/dc/terms/license> <http://creativecommons.org/licenses/by/3.0/> ,
                                                          <https://creativecommons.org/licenses/by/4.0/> ;
                       <http://purl.org/dc/terms/references> <https://doi.org/10.26434/chemrxiv-2024-fvzpq> ;
                       <http://purl.org/dc/terms/title> "GNVC: Gainesville Core Ontology - standard for publishing results of computational chemistry."@en ,
                                                        "GC Core Ontology" ;
                       rdfs:comment "An ontology for publishing results of computational chemistry."@en ,
                                    """The design and repair decisions in this fork were informed in part by the landscape review of computational chemistry ontologies: ChemRxiv 2024,
    doi:10.26434/chemrxiv-2024-fvzpq"""@en ;
                       rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                       owl:versionInfo "0.8.4" .

#################################################################
#    Annotation properties
#################################################################

###  http://creativecommons.org/ns#license
<http://creativecommons.org/ns#license> rdf:type owl:AnnotationProperty .


###  http://purl.obolibrary.org/obo/IAO_0000115
<http://purl.obolibrary.org/obo/IAO_0000115> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/created
<http://purl.org/dc/elements/1.1/created> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/description
<http://purl.org/dc/elements/1.1/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/modified
<http://purl.org/dc/elements/1.1/modified> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/contributor
<http://purl.org/dc/terms/contributor> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/references
<http://purl.org/dc/terms/references> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/source
<http://purl.org/dc/terms/source> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/gc/hasMolecularMechanics
:hasMolecularMechanics rdf:type owl:AnnotationProperty ;
                       rdfs:range xsd:boolean .


###  http://purl.org/gc/hasQuantumMechanics
:hasQuantumMechanics rdf:type owl:AnnotationProperty ;
                     rdfs:range xsd:boolean .


###  http://purl.org/gc/isAbstract
:isAbstract rdf:type owl:AnnotationProperty ;
            rdfs:comment """This annotation should be used to mark entities as abstract.
    Abstract entity is a defined OWL resource that from a data model should never be defined explicitly.

    NOTE!
    Since it's only a annotation property, it doesn't impact a logical definition of an Entity. Such a property should be treated as a \"side note\". """@en ;
            rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
            rdfs:label "is abstract"@en ;
            rdfs:range xsd:boolean .


###  http://purl.org/gc/termStatus
:termStatus rdf:type owl:AnnotationProperty ;
            rdfs:comment """Such a annotation contains information about defined in DMS ontology Axiom status.
    Since it's a text based value, follwing enumerations should be used as values:

    - STABLE (Entity was tested during QA process and is stable)
    - UNSTABLE (Entity is unstable due to some reasone - shouldn't be use till fixed)
    - TESTING (Entity is under testing process)
    - ARCHAIC (old and unused definition - probably will be removed in comming iterations)
    - DEPRECATED (Entity is deprecated due to some reason - should not be used)
    - NEW (new definition)
    - FIX (definition that was made to bring fix for some issue)

    NOTE!
    Since it's only a annotation property, it doesn't impact a logical definition of an Entity. Such a property should be treated as a \"side note\". """@en ;
            rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
            rdfs:label "term status"@en ;
            rdfs:range xsd:string .


###  http://purl.org/gc/termStatusNote
:termStatusNote rdf:type owl:AnnotationProperty ;
                rdfs:comment """This property is a status description of a particular Entity. Combined with log:termStatus contains information aboud current status of an Entity, with a information about history, changes, etc.

    NOTE!
    Since it's only a annotation property, it doesn't impact a logical definition of an Entity. Such a property should be treated as a \"side note\". """@en ;
                rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                rdfs:label "term status note"@en ;
                rdfs:range xsd:string .


###  http://www.w3.org/2000/01/rdf-schema#comment
rdfs:comment rdf:type owl:AnnotationProperty ;
             rdfs:comment ""@en ;
             rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> .


###  http://www.w3.org/ns/prov#category
<http://www.w3.org/ns/prov#category> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/prov#component
<http://www.w3.org/ns/prov#component> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/prov#constraints
<http://www.w3.org/ns/prov#constraints> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/prov#definition
<http://www.w3.org/ns/prov#definition> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/prov#dm
<http://www.w3.org/ns/prov#dm> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/prov#editorialNote
<http://www.w3.org/ns/prov#editorialNote> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/prov#editorsDefinition
<http://www.w3.org/ns/prov#editorsDefinition> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/prov#inverse
<http://www.w3.org/ns/prov#inverse> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/prov#n
<http://www.w3.org/ns/prov#n> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/prov#qualifiedForm
<http://www.w3.org/ns/prov#qualifiedForm> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/prov#sharesDefinitionWith
<http://www.w3.org/ns/prov#sharesDefinitionWith> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://purl.obolibrary.org/obo/BFO_0000124
<http://purl.obolibrary.org/obo/BFO_0000124> rdf:type owl:ObjectProperty .


###  http://purl.org/gc/IsAtomProperty
:IsAtomProperty rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :extraGCObjectProperty ;
                rdfs:comment "A generic atomic property"@en ;
                rdfs:label "Atom Property"@en .


###  http://purl.org/gc/IsSystemProperty
:IsSystemProperty rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :extraGCObjectProperty ;
                  rdfs:comment "A generic system property"@en ;
                  rdfs:label "System Property"@en .


###  http://purl.org/gc/binds
:binds rdf:type owl:ObjectProperty ;
       rdfs:subPropertyOf :hasMolecularProperty ;
       rdfs:domain :Bond ;
       rdfs:range :Atom ;
       rdfs:comment "A property that tells which atoms are bonded."@en ;
       rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
       rdfs:label "the act of binding of atoms"@en .


###  http://purl.org/gc/extraGCDataProperty
:extraGCDataProperty rdf:type owl:ObjectProperty .


###  http://purl.org/gc/extraGCObjectProperty
:extraGCObjectProperty rdf:type owl:ObjectProperty .


###  http://purl.org/gc/hasAtom
:hasAtom rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000124> ,
                            :hasMolecularProperty ;
         rdfs:domain [ rdf:type owl:Class ;
                       owl:unionOf ( :Molecule
                                     :Residue
                                   )
                     ] ;
         rdfs:range :Atom ;
         owl:propertyChainAxiom ( :hasResidue
                                  :hasAtom
                                ) ;
         rdfs:comment "A property that describes atoms comprised by a molecule or residue"@en ,
                      "A property that describes atoms comprised by a molecule or residue."@en ;
         rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
         rdfs:label "has atom"@en .


###  http://purl.org/gc/hasAtomCoordinateX
:hasAtomCoordinateX rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :extraGCObjectProperty ,
                                       :hasCoordinates ;
                    rdfs:domain :Atom ;
                    rdfs:range :FloatValue ;
                    rdfs:comment "A property that describes Atom X coordinate"@en ;
                    rdfs:label "Atom Coordinate X"@en .


###  http://purl.org/gc/hasAtomCoordinateY
:hasAtomCoordinateY rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :extraGCObjectProperty ,
                                       :hasCoordinates ;
                    rdfs:domain :Atom ;
                    rdfs:range :FloatValue ;
                    rdfs:comment "A property that describes Atom Y coordinate"@en ;
                    rdfs:label "Atom Coordinate Y"@en .


###  http://purl.org/gc/hasAtomCoordinateZ
:hasAtomCoordinateZ rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :extraGCObjectProperty ,
                                       :hasCoordinates ;
                    rdfs:domain :Atom ;
                    rdfs:range :FloatValue ;
                    rdfs:comment "A property that describes Atom Z coordinate"@en ;
                    rdfs:label "Atom Coordinate Z"@en .


###  http://purl.org/gc/hasAtomProperty
:hasAtomProperty rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :extraGCObjectProperty ;
                 rdfs:domain :Atom .


###  http://purl.org/gc/hasAuthor
:hasAuthor rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :extraGCObjectProperty ;
           rdfs:domain :Publication ;
           rdfs:range :Author ;
           rdfs:comment "A property that describes teh author"@en ;
           rdfs:label "has author"@en .


###  http://purl.org/gc/hasAuxiliaryProperty
:hasAuxiliaryProperty rdf:type owl:ObjectProperty ;
                      rdfs:domain rdfs:Class ;
                      rdfs:range rdfs:Class ;
                      rdfs:comment "The upper property for various properties related to publications" ;
                      rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                      rdfs:label "Generic Auxiliary Property"@en .


###  http://purl.org/gc/hasBasisCount
:hasBasisCount rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :extraGCObjectProperty ;
               rdfs:comment "A property that specifies the Basis Count."@en ;
               rdfs:label "The Basis Count"@en .


###  http://purl.org/gc/hasBasisSet
:hasBasisSet rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :hasFeature ,
                                :hasMolecularFeature ;
             rdf:type owl:FunctionalProperty ;
             rdfs:domain :Atom ,
                         :MolecularMethodology ;
             rdfs:range :BasisSet .


###  http://purl.org/gc/hasBindingEnergy
:hasBindingEnergy rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :hasSystemEnergiesResult ;
                  rdfs:domain :SystemEnergies ;
                  rdfs:range :FloatValue ;
                  rdfs:comment "A property that allows to assign the Binding Energy to the molecular system"@en ;
                  rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                  rdfs:label "has binding energy"@en .


###  http://purl.org/gc/hasBond
:hasBond rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf :hasMolecularProperty ;
         rdfs:domain :Atom ;
         rdfs:range :Bond ;
         rdfs:comment "A property that allows the bond to be assigned to atoms."@en ;
         rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
         rdfs:label "has bond"@en .


###  http://purl.org/gc/hasBondLength
:hasBondLength rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :hasMolecularProperty ;
               rdfs:domain :Bond ;
               rdfs:range :FloatValue ;
               rdfs:comment "A property that allows bond length to be assigned the a bond."@en ;
               rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
               rdfs:label "has bond length"@en .


###  http://purl.org/gc/hasBondOrder
:hasBondOrder rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :extraGCObjectProperty ;
              rdfs:domain :Bond .


###  http://purl.org/gc/hasBondType
:hasBondType rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :extraGCObjectProperty ;
             rdfs:domain :Bond ;
             rdfs:range :BondTypes .


###  http://purl.org/gc/hasCalculatedAtomCharge
:hasCalculatedAtomCharge rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf :hasResult ;
                         rdfs:domain :Atom ;
                         rdfs:range :FloatValue ;
                         rdfs:comment "A property that describes the atom charge calculated by a specific methodology."@en ;
                         rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                         rdfs:label "has calculated atom charge"@en .


###  http://purl.org/gc/hasCalculation
:hasCalculation rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :extraGCObjectProperty ;
                rdfs:comment "A property that specifies the calculation."@en ;
                rdfs:label "Calculation"@en .


###  http://purl.org/gc/hasCalculationOn
:hasCalculationOn rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :hasResult ;
                  rdfs:domain :MolecularSystem ;
                  rdfs:comment "A property that tells whether the molecular system has calculations done."@en ;
                  rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                  rdfs:label "has calculation on"@en .


###  http://purl.org/gc/hasCollectionEntry
:hasCollectionEntry rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :extraGCObjectProperty ;
                    rdfs:comment "A property that specifies the Collection Entry."@en ;
                    rdfs:label "Collection Entry"@en .


###  http://purl.org/gc/hasCoordinates
:hasCoordinates rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :hasMolecularProperty ;
                rdfs:domain :Atom ;
                rdfs:range :VectorValue ;
                rdfs:comment "A property that describes atom coordinates."@en ;
                rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                rdfs:label "has coordinates"@en .


###  http://purl.org/gc/hasCorrelationEnergy
:hasCorrelationEnergy rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf :hasSystemEnergiesResult ;
                      rdfs:domain :SystemEnergies ;
                      rdfs:range :FloatValue ;
                      rdfs:comment "A property that describes system correlation energy."@en ;
                      rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                      rdfs:label "has correlation Energy"@en .


###  http://purl.org/gc/hasCorrelationFunctional
:hasCorrelationFunctional rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf :hasFeature ;
                          rdfs:domain :MolecularMethodology ;
                          rdfs:range :CorrelationFunctional ;
                          rdfs:comment "A property that describes the correlation functional for the given methodology."@en ;
                          rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                          rdfs:label "has correlation functional"@en .


###  http://purl.org/gc/hasDftFlavor
:hasDftFlavor rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :hasFeature ;
              rdfs:domain :MolecularMethodology ;
              rdfs:range :DftFlavor ;
              rdfs:comment "A property that describes specific approximations to exchange-correlation functionals in the Density Functional Theory."@en ;
              rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
              rdfs:label "has DFT flavor"@en .


###  http://purl.org/gc/hasDftFunctional
:hasDftFunctional rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :hasFeature ;
                  rdfs:domain :MolecularMethodology ;
                  rdfs:range :DensityFunctional ;
                  rdfs:comment "A property that describes DFT Functionals for the given methodology."@en ;
                  rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                  rdfs:label "has DFT functional"@en .


###  http://purl.org/gc/hasDipoleMoment
:hasDipoleMoment rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :hasDipoleResult ;
                 rdfs:domain :CalculatedSystemProperties ;
                 rdfs:range :VectorValue ;
                 rdfs:comment "A property that describes molecular dipole moment."@en ;
                 rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                 rdfs:label "has dipole moment"@en .


###  http://purl.org/gc/hasDipoleMomentAverage
:hasDipoleMomentAverage rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf :hasDipoleResult ;
                        rdfs:domain :CalculatedSystemProperties ;
                        rdfs:range :FloatValue ;
                        rdfs:comment "A property that describes the average molecular dipole moment."@en ;
                        rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                        rdfs:label "has dipole moment average"@en .


###  http://purl.org/gc/hasDipoleMomentX
:hasDipoleMomentX rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :extraGCObjectProperty ,
                                     :hasDipoleMoment ;
                  rdfs:domain :CalculatedSystemProperties ;
                  rdfs:range :FloatValue ;
                  rdfs:comment "A property that reports dipole moment X component"@en ;
                  rdfs:label "Dipole Moment X component"@en .


###  http://purl.org/gc/hasDipoleMomentY
:hasDipoleMomentY rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :extraGCObjectProperty ,
                                     :hasDipoleMoment ;
                  rdfs:domain :CalculatedSystemProperties ;
                  rdfs:range :FloatValue ;
                  rdfs:comment "A property ... "@en ;
                  rdfs:label "Dipole Moment Y component"@en .


###  http://purl.org/gc/hasDipoleMomentZ
:hasDipoleMomentZ rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :extraGCObjectProperty ,
                                     :hasDipoleMoment ;
                  rdfs:domain :CalculatedSystemProperties ;
                  rdfs:range :FloatValue ;
                  rdfs:comment "A property ... "@en ;
                  rdfs:label "Dipole Moment Z component"@en .


###  http://purl.org/gc/hasDipoleResult
:hasDipoleResult rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :hasResult ;
                 :isAbstract "true"^^xsd:boolean ;
                 rdfs:comment "A property that describes molecular dipole moment."@en ;
                 rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                 rdfs:label "has dipole result"@en .


###  http://purl.org/gc/hasDispersionCorrection
:hasDispersionCorrection rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf :hasFeature ;
                         rdfs:domain :MolecularMethodology ;
                         rdfs:range :DispersionCorrection ;
                         rdfs:comment "A property that describes the dispersion correction"@en ;
                         rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                         rdfs:label "has dispersion correction"@en .


###  http://purl.org/gc/hasElectronicEnergy
:hasElectronicEnergy rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf :hasSystemEnergiesResult ;
                     rdfs:domain :SystemEnergies ;
                     rdfs:range :FloatValue ;
                     rdfs:comment "A property that describes the electronic energy."@en ;
                     rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                     rdfs:label "has electronic energy"@en .


###  http://purl.org/gc/hasElectronicSpectraResult
:hasElectronicSpectraResult rdf:type owl:ObjectProperty ;
                            rdfs:subPropertyOf :hasResult ;
                            rdfs:comment "A property that describes the electronic spectra."@en ;
                            rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                            rdfs:label "has electronic spectra result"@en .


###  http://purl.org/gc/hasElectronicTransitions
:hasElectronicTransitions rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf :hasElectronicSpectraResult ;
                          rdfs:domain :ElectronicSpectra ;
                          rdfs:range :VectorValue ;
                          rdfs:comment "A property that describes electronic transition energies."@en ;
                          rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                          rdfs:label "has electronic transitions"@en .


###  http://purl.org/gc/hasEnthalpy
:hasEnthalpy rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :hasSystemEnergiesResult ;
             rdfs:domain :SystemEnergies ;
             rdfs:range :FloatValue ;
             rdfs:comment "A property that describes the enthalpy."@en ;
             rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
             rdfs:label "has enthalpy"@en .


###  http://purl.org/gc/hasEntropy
:hasEntropy rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :hasSystemEnergiesResult ;
            rdfs:domain :SystemEnergies ;
            rdfs:range :FloatValue ;
            rdfs:comment "A property that describes the entropy."@en ;
            rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
            rdfs:label "has entropy"@en .


###  http://purl.org/gc/hasExchangeFunctional
:hasExchangeFunctional rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf :hasFeature ;
                       rdfs:domain :MolecularMethodology ;
                       rdfs:range :ExchangeFunctional ;
                       rdfs:comment "A property that describes the exchange functionals."@en ;
                       rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                       rdfs:label "has exchange functional"@en .


###  http://purl.org/gc/hasExcitedStateMethod
:hasExcitedStateMethod rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf :hasMolecularFeature ;
                       rdf:type owl:FunctionalProperty ;
                       rdfs:domain :ElectronicSpectra .


###  http://purl.org/gc/hasFeature
:hasFeature rdf:type owl:ObjectProperty ;
            rdfs:domain :MolecularMethodology ;
            rdfs:range :MethodologyFeature ;
            rdfs:comment "A property that describes a specific feature of given methodology."@en ,
                         "has feature" ;
            rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
            rdfs:label "has feature"@en .


###  http://purl.org/gc/hasFile
:hasFile rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf :hasAuxiliaryProperty ;
         rdfs:domain :ComputationalChemistryPublication .


###  http://purl.org/gc/hasFloatVector
:hasFloatVector rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :extraGCObjectProperty ;
                rdfs:comment "A property that specifies the Float Vector."@en ;
                rdfs:label "Float Vector"@en .


###  http://purl.org/gc/hasForceField
:hasForceField rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :hasFeature ,
                                  :hasMolecularFeature ;
               rdfs:domain :MolecularMechanics ,
                           :MolecularMethodology ;
               rdfs:range :ForceField .


###  http://purl.org/gc/hasFormalCharge
:hasFormalCharge rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :hasMolecularProperty ;
                 rdfs:domain :Atom ;
                 rdfs:range :IntegerValue ;
                 rdfs:comment "A property that descibes the formal charge. The formal charge is the charge assigned to an atom in a molecule, assuming that electrons in a chemical bond are shared equally between atoms, regardless of relative electronegativity."@en ;
                 rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
                 rdfs:label "has formal charge"@en .


###  http://purl.org/gc/hasFrequency
:hasFrequency rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :hasResult ;
              rdfs:domain :FrequencyPeak ;
              rdfs:range :FloatValue ;
              rdfs:comment "A property that describes the value of a frequency at the peak of the spectrum."@en ;
              rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
              rdfs:label "has frequency"@en .


###  http://purl.org/gc/hasFrequencyPeak
:hasFrequencyPeak rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :hasResult ;

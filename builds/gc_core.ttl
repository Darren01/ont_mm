###  http://purl.org/gc/WaveFunction
:WaveFunction rdf:type owl:Class ;
              rdfs:subClassOf :CalculationResult ,
                              :GainesvilleCoreTerm ;
              <http://purl.obolibrary.org/obo/IAO_0000115> """The solution of the Schrödinger equation, eigenfunction of the hamiltonian operator. Complex conjugate functions are denoted by an asterisk read
        as 'star'."""@en ;
              <http://purl.org/dc/terms/source> "Green Book, 2nd ed., p. 16 "@en ;
              rdfs:comment "A class for WaveFunction."@en ,
                           "A class for the mathematical description of a quantum particle, in most practical cases of the electron."@en ;
              rdfs:isDefinedBy <http://chemicalsemantics.com/> ;
              rdfs:label "Wave Function"@en ;
              rdfs:seeAlso <https://doi.org/10.1351/goldbook.W06657> ,
                           <https://goldbook.iupac.org/terms/view/W06657> .


